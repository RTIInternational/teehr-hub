{
  "version": 1,
  "profiles": [
    {
      "display_name": "TEEHR Evaluation System (local)",
      "default": true,
      "description": "A node on the local KIND cluster",
      "profile_options": {
        "image": {
          "display_name": "Image",
          "choices": {
            "current-tag": {
              "display_name": "Bleeding Edge ${slice(var.devTeehrVersion, 0, 6)}",
              "default": true,
              "kubespawner_override": {
                "image": "${actions.build.teehr-jupyter-driver-image-edge.outputs.deploymentImageId}"
              }
            }
          }
        }
      },
      "kubespawner_override": {
        "node_selector": {
          "teehr-hub/nodegroup-name": "nb-r5-xlarge"
        }
      }
    },
    {
      "display_name": "HEFS-FEWS Evaluation System (local)",
      "default": false,
      "description": "A node on the local KIND cluster",
      "profile_options": {
        "image": {
          "display_name": "Image",
          "choices": {
            "v0-3-0": {
              "display_name": "Version 0.3.x",
              "default": true,
              "kubespawner_override": {
                "image": "hefs-hub:0.3.0"
              }
            }
          }
        }
      },
      "kubespawner_override": {
        "image_pull_policy": "IfNotPresent",
        "node_selector": {
          "teehr-hub/nodegroup-name": "nb-r5-xlarge"
        }
      }
    }
  ]
}
