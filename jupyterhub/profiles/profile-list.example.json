{
  "version": 1,
  "profiles": [
    {
      "display_name": "TEEHR Project",
      "default": true,
      "description": "Choose this profile for work related to the TEEHR Project.",
      "profile_options": {
        "image": {
          "display_name": "Image",
          "choices": {
            "stable-xlarge": {
              "display_name": "Stable - XL (4 cores, 16 GB memory)",
              "default": true,
              "kubespawner_override": {
                "image": "123456789012.dkr.ecr.us-west-2.amazonaws.com/teehr-jupyter-driver:0.7.0",
                "mem_limit": "32G",
                "mem_guarantee": "19G",
                "cpu_limit": 4,
                "cpu_guarantee": 3,
                "node_selector": {
                  "teehr-hub/nodegroup-name": "nb-r5-xlarge"
                }
              }
            }
          }
        }
      },
      "kubespawner_override": {
        "environment": {
          "TEEHR_PROJECT_ID": "TEEHR"
        }
      }
    }
  ]
}
